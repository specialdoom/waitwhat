<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Todos"
        android:textSize="13sp"
        android:textColor="#6750A4"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <!-- slot 0 -->
    <LinearLayout android:id="@+id/slot_0"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingBottom="5dp" android:visibility="gone">
        <TextView android:id="@+id/priority_0"
            android:layout_width="4dp" android:layout_height="24dp"
            android:layout_marginEnd="8dp" android:text="" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/title_0"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#1C1B1F"
                android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/due_0"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#6750A4" android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- slot 1 -->
    <LinearLayout android:id="@+id/slot_1"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingBottom="5dp" android:visibility="gone">
        <TextView android:id="@+id/priority_1"
            android:layout_width="4dp" android:layout_height="24dp"
            android:layout_marginEnd="8dp" android:text="" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/title_1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#1C1B1F"
                android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/due_1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#6750A4" android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- slot 2 -->
    <LinearLayout android:id="@+id/slot_2"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingBottom="5dp" android:visibility="gone">
        <TextView android:id="@+id/priority_2"
            android:layout_width="4dp" android:layout_height="24dp"
            android:layout_marginEnd="8dp" android:text="" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/title_2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#1C1B1F"
                android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/due_2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#6750A4" android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- slot 3 -->
    <LinearLayout android:id="@+id/slot_3"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingBottom="5dp" android:visibility="gone">
        <TextView android:id="@+id/priority_3"
            android:layout_width="4dp" android:layout_height="24dp"
            android:layout_marginEnd="8dp" android:text="" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/title_3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#1C1B1F"
                android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/due_3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#6750A4" android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- slot 4 -->
    <LinearLayout android:id="@+id/slot_4"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingBottom="5dp" android:visibility="gone">
        <TextView android:id="@+id/priority_4"
            android:layout_width="4dp" android:layout_height="24dp"
            android:layout_marginEnd="8dp" android:text="" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/title_4"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#1C1B1F"
                android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/due_4"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#6750A4" android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <TextView android:id="@+id/empty_view"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:paddingTop="8dp"
        android:text="No pending todos"
        android:textSize="12sp" android:textColor="#79747E"
        android:visibility="gone" />

</LinearLayout>
